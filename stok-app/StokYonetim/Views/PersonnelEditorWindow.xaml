<Window x:Class="StokYonetim.Views.PersonnelEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Personel" Height="620" Width="560" MinHeight="580" MinWidth="520"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource BgBrush}" WindowStyle="SingleBorderWindow">
    <Grid Margin="16">
        <Border Background="White" CornerRadius="12" BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1" Padding="24,24,24,20">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="TitleText" Grid.Row="0" Text="Yeni personel" FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}" Margin="0,0,0,6"/>
                    <TextBlock Grid.Row="1" Text="Personel bilgilerini girin ve kaydedin."
                               Foreground="{StaticResource MutedBrush}" FontSize="13" Margin="0,0,0,20"/>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.ColumnSpan="3" Margin="0,0,0,12">
                            <TextBlock Text="Ad soyad" Style="{StaticResource FormLabel}"/>
                            <TextBox x:Name="FullNameBox" Style="{StaticResource InputBox}" MaxLength="120"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,12">
                            <TextBlock Text="E-posta" Style="{StaticResource FormLabel}"/>
                            <TextBox x:Name="EmailBox" Style="{StaticResource InputBox}" MaxLength="254"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,12">
                            <TextBlock Text="Telefon" Style="{StaticResource FormLabel}"/>
                            <TextBox x:Name="PhoneBox" Style="{StaticResource InputBox}" MaxLength="14"
                                     ToolTip="0XXX XXX XX XX"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="0">
                            <TextBlock Text="Doğum tarihi" Style="{StaticResource FormLabel}"/>
                            <Border x:Name="BirthDateBorder" Background="White"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                    CornerRadius="8" Height="42">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="40" Background="{StaticResource AccentSoftBrush}" CornerRadius="8,0,0,8">
                                        <TextBlock Text="📅" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBox x:Name="BirthDateBox" Grid.Column="1" MaxLength="10"
                                             BorderThickness="0" Background="Transparent"
                                             VerticalContentAlignment="Center" Padding="10,0,12,0"
                                             FontSize="14" Foreground="{StaticResource TextBrush}"
                                             ToolTip="GG/AA/YYYY"/>
                                </Grid>
                            </Border>
                            <TextBlock x:Name="BirthDateHint" Text="GG/AA/YYYY" FontSize="11"
                                       Foreground="{StaticResource MutedBrush}" Margin="2,4,0,0"/>
                            <TextBlock x:Name="BirthDateErrorText" FontSize="11"
                                       Foreground="{StaticResource DangerBrush}" Margin="2,4,0,0"
                                       TextWrapping="Wrap" Visibility="Collapsed"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="2">
                            <TextBlock Text="Maaş (₺)" Style="{StaticResource FormLabel}"/>
                            <TextBox x:Name="SalaryBox" Style="{StaticResource InputBox}" MaxLength="14"/>
                        </StackPanel>

                        <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,12,0,0">
                            <TextBlock Text="Rol" Style="{StaticResource FormLabel}"/>
                            <ComboBox x:Name="RoleCombo" Style="{StaticResource AppComboBox}" IsEditable="False"/>
                        </StackPanel>

                        <StackPanel x:Name="IsActivePanel" Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3"
                                    Margin="0,14,0,0" Visibility="Collapsed">
                            <CheckBox x:Name="IsActiveCheck" Content="Aktif" FontSize="14"
                                      Foreground="{StaticResource TextBrush}" IsChecked="True"/>
                            <TextBlock Text="Personelin şu anda aktif olarak çalışıp çalışmadığını belirtir."
                                       FontSize="11" Foreground="{StaticResource MutedBrush}" Margin="2,6,0,0"/>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="3" Margin="0,24,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Content="İptal" Style="{StaticResource SecondaryButton}" Height="44" Click="Cancel_Click"/>
                        <Button x:Name="SaveBtn" Grid.Column="2" Content="Kaydet" Style="{StaticResource PrimaryButton}"
                                Height="44" Click="Save_Click"/>
                    </Grid>
                </Grid>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
