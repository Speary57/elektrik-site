<Window x:Class="StokYonetim.Views.PersonnelPayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Maaş Öde" Height="560" Width="480" MinHeight="520" MinWidth="440"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource BgBrush}" WindowStyle="SingleBorderWindow">
    <Grid Margin="16">
        <Border Background="White" CornerRadius="12" BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1" Padding="24,24,24,20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Maaş ödemesi" FontSize="20" FontWeight="Bold"
                           Foreground="{StaticResource TextBrush}" Margin="0,0,0,6"/>
                <TextBlock Grid.Row="1" Text="Personel, ödeme türü ve miktarı seçin."
                           Foreground="{StaticResource MutedBrush}" FontSize="13" Margin="0,0,0,16"/>

                <StackPanel Grid.Row="2" Margin="0,0,0,14">
                    <TextBlock Text="Personel" Style="{StaticResource FormLabel}"/>
                    <ComboBox x:Name="PersonnelCombo" Style="{StaticResource AppComboBox}"
                              DisplayMemberPath="DisplayName" SelectionChanged="PersonnelCombo_SelectionChanged"/>
                </StackPanel>

                <StackPanel Grid.Row="3" Margin="0,0,0,14">
                    <TextBlock Text="Ödeme" Style="{StaticResource FormLabel}"/>
                    <ComboBox x:Name="PaymentTypeCombo" Style="{StaticResource AppComboBox}"
                              SelectionChanged="PaymentTypeCombo_SelectionChanged"/>
                </StackPanel>

                <StackPanel Grid.Row="4" Margin="0,0,0,8">
                    <TextBlock Text="Miktar (₺)" Style="{StaticResource FormLabel}"/>
                    <TextBox x:Name="AmountBox" Style="{StaticResource InputBox}" MaxLength="14"/>
                </StackPanel>

                <TextBlock Grid.Row="5" x:Name="ErrorText" Foreground="#DC2626" FontSize="13"
                           Margin="0,4,0,0" Visibility="Collapsed" TextWrapping="Wrap"/>

                <Grid Grid.Row="6" Margin="0,20,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Content="İptal" Style="{StaticResource SecondaryButton}" Height="44" Click="Cancel_Click"/>
                    <Button Grid.Column="2" Content="Kaydet" Style="{StaticResource PrimaryButton}" Height="44"
                            Click="Save_Click"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
