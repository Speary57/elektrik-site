<UserControl x:Class="StokYonetim.Views.Pages.PersonnelPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Personeller" Style="{StaticResource PageTitle}"/>
                <TextBlock Text="Personel ekleyin, maaş ödemesi yapın. Düzenlemek için satıra çift tıklayın."
                           Style="{StaticResource PageSubtitle}"/>
            </StackPanel>
            <Border Grid.Column="1" Style="{StaticResource CountBadge}">
                <TextBlock x:Name="CountBadge" Foreground="{StaticResource PrimaryBrush}" FontSize="12" FontWeight="SemiBold"/>
            </Border>
        </Grid>

        <Border Grid.Row="1" Style="{StaticResource SectionCard}" Padding="20" Margin="0,0,0,16">
            <Grid>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="ScheduleHintText" Foreground="{StaticResource MutedBrush}" FontSize="13"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="AddPersonnelBtn" Content="Personel ekle" Style="{StaticResource PrimaryButton}"
                            MinWidth="140" Height="42" Click="AddPersonnel_Click"/>
                    <Button x:Name="PaySalaryBtn" Content="Maaş öde" Style="{StaticResource SecondaryButton}"
                            MinWidth="130" Height="42" Margin="12,0,0,0" Click="PaySalary_Click"/>
                    <Button x:Name="SalaryScheduleBtn" Content="Maaş günü ayarla" Style="{StaticResource SecondaryButton}"
                            MinWidth="150" Height="42" Margin="12,0,0,0" Click="SalarySchedule_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource SectionCard}" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#F8FAFC" BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,0,0,1" Padding="4,4,4,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.2*"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="1.1*"/>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="90"/>
                        </Grid.ColumnDefinitions>
                        <Button Style="{StaticResource SortHeaderButton}" Tag="Name" Click="SortHeader_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Ad soyad" Style="{StaticResource TableHeaderText}"/>
                                <TextBlock x:Name="NameSortArrow" Grid.Column="1" Text="▲" FontSize="10"
                                           Foreground="{StaticResource PrimaryBrush}" Margin="8,0,4,0" VerticalAlignment="Center"/>
                            </Grid>
                        </Button>
                        <Button Grid.Column="1" Style="{StaticResource SortHeaderButton}" Tag="Role" Click="SortHeader_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Rol" Style="{StaticResource TableHeaderText}"/>
                                <TextBlock x:Name="RoleSortArrow" Grid.Column="1" Text="" FontSize="10"
                                           Foreground="{StaticResource PrimaryBrush}" Margin="8,0,4,0" VerticalAlignment="Center"/>
                            </Grid>
                        </Button>
                        <Button Grid.Column="2" Style="{StaticResource SortHeaderButton}" Tag="Active" Click="SortHeader_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Durum" Style="{StaticResource TableHeaderText}"/>
                                <TextBlock x:Name="ActiveSortArrow" Grid.Column="1" Text="" FontSize="10"
                                           Foreground="{StaticResource PrimaryBrush}" Margin="8,0,4,0" VerticalAlignment="Center"/>
                            </Grid>
                        </Button>
                        <Button Grid.Column="3" Style="{StaticResource SortHeaderButton}" Tag="Email" Click="SortHeader_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="E-posta" Style="{StaticResource TableHeaderText}"/>
                                <TextBlock x:Name="EmailSortArrow" Grid.Column="1" Text="" FontSize="10"
                                           Foreground="{StaticResource PrimaryBrush}" Margin="8,0,4,0" VerticalAlignment="Center"/>
                            </Grid>
                        </Button>
                        <Button Grid.Column="4" Style="{StaticResource SortHeaderButton}" Tag="Phone" Click="SortHeader_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Telefon" Style="{StaticResource TableHeaderText}"/>
                                <TextBlock x:Name="PhoneSortArrow" Grid.Column="1" Text="" FontSize="10"
                                           Foreground="{StaticResource PrimaryBrush}" Margin="8,0,4,0" VerticalAlignment="Center"/>
                            </Grid>
                        </Button>
                        <Button Grid.Column="5" Style="{StaticResource SortHeaderButton}" Tag="Birth" Click="SortHeader_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Doğum" Style="{StaticResource TableHeaderText}"/>
                                <TextBlock x:Name="BirthSortArrow" Grid.Column="1" Text="" FontSize="10"
                                           Foreground="{StaticResource PrimaryBrush}" Margin="8,0,4,0" VerticalAlignment="Center"/>
                            </Grid>
                        </Button>
                        <Button Grid.Column="6" Style="{StaticResource SortHeaderButton}" Tag="Salary" Click="SortHeader_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Maaş" Style="{StaticResource TableHeaderText}"/>
                                <TextBlock x:Name="SalarySortArrow" Grid.Column="1" Text="" FontSize="10"
                                           Foreground="{StaticResource PrimaryBrush}" Margin="8,0,4,0" VerticalAlignment="Center"/>
                            </Grid>
                        </Button>
                    </Grid>
                </Border>

                <ListView x:Name="PersonnelList" Grid.Row="1" BorderThickness="0" Background="Transparent"
                          Padding="8,4" MinHeight="120" MouseDoubleClick="PersonnelList_MouseDoubleClick"
                          SelectionChanged="PersonnelList_SelectionChanged">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,2"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <Border x:Name="row" Background="Transparent" CornerRadius="8" Padding="4,2">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="row" Property="Background" Value="#F8FAFC"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="row" Property="Background" Value="{StaticResource AccentSoftBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="8,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.2*"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="1.1*"/>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="90"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding FullName}" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding Role}" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="{Binding ActiveDisplay}" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{Binding ActiveBrush}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="3" Text="{Binding Email}" FontSize="13"
                                           Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Column="4" Text="{Binding Phone}" FontSize="13"
                                           Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="5" Text="{Binding BirthDateDisplay}" FontSize="13"
                                           Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="6" Text="{Binding SalaryDisplay}" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <Border Grid.Row="2" Style="{StaticResource FooterBar}">
                    <Grid>
                        <TextBlock x:Name="FooterHint" Foreground="{StaticResource MutedBrush}" FontSize="12"
                                   VerticalAlignment="Center" Text="Düzenlemek için satıra çift tıklayın."/>
                        <Button Content="Seçili personeli sil" Style="{StaticResource DangerButton}"
                                HorizontalAlignment="Right" Click="Delete_Click" IsEnabled="False" x:Name="DeleteBtn"/>
                    </Grid>
                </Border>

                <TextBlock x:Name="EmptyText" Grid.Row="1" Text="Henüz personel kaydı yok. Personel ekle butonuyla başlayın."
                           Foreground="{StaticResource MutedBrush}" FontSize="14"
                           HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,40"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
