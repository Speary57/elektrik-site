<UserControl x:Class="StokYonetim.Views.Pages.UsersPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Kullanıcılar" Style="{StaticResource PageTitle}"/>
                <TextBlock Text="Uygulamaya giriş yapabilecek kullanıcıları ekleyin ve yönetin."
                           Style="{StaticResource PageSubtitle}"/>
            </StackPanel>
            <Border Grid.Column="1" Style="{StaticResource CountBadge}">
                <TextBlock x:Name="CountBadge" Foreground="{StaticResource PrimaryBrush}" FontSize="12" FontWeight="SemiBold"/>
            </Border>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <Border Style="{StaticResource SectionCard}" Padding="20" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock x:Name="FormTitle" Text="Yeni kullanıcı" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}" Margin="0,0,0,16"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.ColumnSpan="3" Margin="0,0,0,12">
                                <TextBlock Text="E-posta" Style="{StaticResource FormLabel}"/>
                                <TextBox x:Name="EmailBox" Style="{StaticResource InputBox}" MaxLength="254"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,12">
                                <TextBlock Text="Şifre" Style="{StaticResource FormLabel}"/>
                                <PasswordBox x:Name="PasswordBox" Height="42" Padding="12,10" FontSize="14"
                                             BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"/>
                                <TextBlock x:Name="PasswordHint" Text="Düzenlemede boş bırakırsanız şifre değişmez."
                                           FontSize="11" Foreground="{StaticResource MutedBrush}" Margin="2,4,0,0"
                                           Visibility="Collapsed"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,12">
                                <TextBlock Text="Rol" Style="{StaticResource FormLabel}"/>
                                <ComboBox x:Name="RoleCombo" Style="{StaticResource AppComboBox}"/>
                            </StackPanel>

                            <TextBlock Grid.Row="2" Grid.ColumnSpan="3" FontSize="12" Foreground="{StaticResource MutedBrush}"
                                       TextWrapping="Wrap"
                                       Text="Çalışan rolündeki kullanıcılar uygulamaya giriş yapamaz. Depo: ürün ve stok yönetimi. Muhasebeci: stok görüntüleme."/>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                            <Button x:Name="SaveBtn" Content="Kullanıcı ekle" Style="{StaticResource PrimaryButton}"
                                    Height="42" MinWidth="130" Click="Save_Click"/>
                            <Button Content="Temizle" Style="{StaticResource SecondaryButton}" Height="42" MinWidth="100"
                                    Margin="10,0,0,0" Click="Clear_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionCard}" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="#F8FAFC" BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="0,0,0,1" Padding="4,4,4,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="160"/>
                                </Grid.ColumnDefinitions>
                                <Button Style="{StaticResource SortHeaderButton}" Tag="Email" Click="SortHeader_Click">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="E-posta" Style="{StaticResource TableHeaderText}"/>
                                        <TextBlock x:Name="EmailSortArrow" Grid.Column="1" Text="▲" FontSize="10"
                                                   Foreground="{StaticResource PrimaryBrush}" Margin="8,0,4,0" VerticalAlignment="Center"/>
                                    </Grid>
                                </Button>
                                <Button Grid.Column="1" Style="{StaticResource SortHeaderButton}" Tag="Role" Click="SortHeader_Click">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Rol" Style="{StaticResource TableHeaderText}"/>
                                        <TextBlock x:Name="RoleSortArrow" Grid.Column="1" Text="" FontSize="10"
                                                   Foreground="{StaticResource PrimaryBrush}" Margin="8,0,4,0" VerticalAlignment="Center"/>
                                    </Grid>
                                </Button>
                                <Button Grid.Column="2" Style="{StaticResource SortHeaderButton}" Tag="Created" Click="SortHeader_Click">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Eklenme" Style="{StaticResource TableHeaderText}"/>
                                        <TextBlock x:Name="CreatedSortArrow" Grid.Column="1" Text="" FontSize="10"
                                                   Foreground="{StaticResource PrimaryBrush}" Margin="8,0,4,0" VerticalAlignment="Center"/>
                                    </Grid>
                                </Button>
                            </Grid>
                        </Border>

                        <ListView x:Name="UsersList" Grid.Row="1" BorderThickness="0" Background="Transparent"
                                  Padding="8,4" MinHeight="120" MouseDoubleClick="UsersList_MouseDoubleClick"
                                  SelectionChanged="UsersList_SelectionChanged">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0,2"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListViewItem">
                                                <Border x:Name="row" Background="Transparent" CornerRadius="8" Padding="4,2">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="row" Property="Background" Value="#F8FAFC"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="row" Property="Background" Value="{StaticResource AccentSoftBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="8,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.5*"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="160"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Email}" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Role}" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding CreatedAtDisplay}" FontSize="13"
                                                   Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <Border Grid.Row="2" Style="{StaticResource FooterBar}">
                            <Grid>
                                <TextBlock x:Name="FooterHint" Foreground="{StaticResource MutedBrush}" FontSize="12"
                                           VerticalAlignment="Center" Text="Düzenlemek için satıra çift tıklayın."/>
                                <Button Content="Seçili kullanıcıyı sil" Style="{StaticResource DangerButton}"
                                        HorizontalAlignment="Right" Click="Delete_Click" IsEnabled="False" x:Name="DeleteBtn"/>
                            </Grid>
                        </Border>

                        <TextBlock x:Name="EmptyText" Grid.Row="1" Text="Henüz kullanıcı kaydı yok. Yukarıdaki formdan ekleyin."
                                   Foreground="{StaticResource MutedBrush}" FontSize="14"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,40"/>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
