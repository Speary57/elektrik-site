<UserControl x:Class="StokYonetim.Views.Pages.OrdersListPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Siparişler" Style="{StaticResource PageTitle}"/>
                <TextBlock Text="Kayıtlı siparişleri görüntüleyin. Detay için bir siparişe çift tıklayın."
                           Style="{StaticResource PageSubtitle}"/>
            </StackPanel>
            <Border Grid.Column="1" Style="{StaticResource CountBadge}">
                <TextBlock x:Name="CountBadge" Foreground="{StaticResource PrimaryBrush}" FontSize="12" FontWeight="SemiBold"/>
            </Border>
        </Grid>

        <Border Grid.Row="1" Style="{StaticResource SectionCard}" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#F8FAFC" BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,0,0,1" Padding="4,4,4,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="1.1*"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="110"/>
                        </Grid.ColumnDefinitions>
                        <Button Style="{StaticResource SortHeaderButton}" Tag="Date" Click="SortHeader_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Tarih" Style="{StaticResource TableHeaderText}"/>
                                <TextBlock x:Name="DateSortArrow" Grid.Column="1" Text="▲" FontSize="10"
                                           Foreground="{StaticResource PrimaryBrush}" Margin="8,0,4,0" VerticalAlignment="Center"/>
                            </Grid>
                        </Button>
                        <Button Grid.Column="1" Style="{StaticResource SortHeaderButton}" Tag="Customer" Click="SortHeader_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Müşteri" Style="{StaticResource TableHeaderText}"/>
                                <TextBlock x:Name="CustomerSortArrow" Grid.Column="1" Text="" FontSize="10"
                                           Foreground="{StaticResource PrimaryBrush}" Margin="8,0,4,0" VerticalAlignment="Center"/>
                            </Grid>
                        </Button>
                        <Button Grid.Column="2" Style="{StaticResource SortHeaderButton}" Tag="Phone" Click="SortHeader_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Telefon" Style="{StaticResource TableHeaderText}"/>
                                <TextBlock x:Name="PhoneSortArrow" Grid.Column="1" Text="" FontSize="10"
                                           Foreground="{StaticResource PrimaryBrush}" Margin="8,0,4,0" VerticalAlignment="Center"/>
                            </Grid>
                        </Button>
                        <Button Grid.Column="3" Style="{StaticResource SortHeaderButton}" Tag="Count" Click="SortHeader_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Kalem" Style="{StaticResource TableHeaderText}"/>
                                <TextBlock x:Name="CountSortArrow" Grid.Column="1" Text="" FontSize="10"
                                           Foreground="{StaticResource PrimaryBrush}" Margin="8,0,4,0" VerticalAlignment="Center"/>
                            </Grid>
                        </Button>
                        <Button Grid.Column="4" Style="{StaticResource SortHeaderButton}" Tag="Total" Click="SortHeader_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Toplam" Style="{StaticResource TableHeaderText}"/>
                                <TextBlock x:Name="TotalSortArrow" Grid.Column="1" Text="" FontSize="10"
                                           Foreground="{StaticResource PrimaryBrush}" Margin="8,0,4,0" VerticalAlignment="Center"/>
                            </Grid>
                        </Button>
                    </Grid>
                </Border>

                <ListView x:Name="OrdersList" Grid.Row="1" BorderThickness="0" Background="Transparent"
                          Padding="8,4" MouseDoubleClick="OrdersList_MouseDoubleClick"
                          SelectionChanged="OrdersList_SelectionChanged">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,2"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <Border x:Name="row" Background="Transparent" CornerRadius="8" Padding="4,2">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="row" Property="Background" Value="#F8FAFC"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="row" Property="Background" Value="{StaticResource AccentSoftBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="8,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="1.1*"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="110"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding CreatedAtDisplay}" FontSize="13"
                                           Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding CustomerName}" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="{Binding CustomerPhone}" FontSize="13"
                                           Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="3" Text="{Binding ItemCount}" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="4" Text="{Binding TotalAmountDisplay}" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <Border Grid.Row="2" Style="{StaticResource FooterBar}">
                    <Grid>
                        <TextBlock x:Name="FooterHint" Foreground="{StaticResource MutedBrush}" FontSize="12"
                                   VerticalAlignment="Center" Text="Detay için siparişe çift tıklayın."/>
                        <Button Content="Seçili siparişi sil" Style="{StaticResource DangerButton}"
                                HorizontalAlignment="Right" Click="Delete_Click" IsEnabled="False" x:Name="DeleteBtn"/>
                    </Grid>
                </Border>

                <TextBlock x:Name="EmptyText" Grid.Row="1" Text="Henüz sipariş yok. Sipariş Ekle bölümünden kayıt oluşturun."
                           Foreground="{StaticResource MutedBrush}" FontSize="14"
                           HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,40"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
