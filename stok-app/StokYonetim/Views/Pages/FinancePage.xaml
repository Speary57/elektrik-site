<UserControl x:Class="StokYonetim.Views.Pages.FinancePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Gelir / Gider" Style="{StaticResource PageTitle}"/>
                <TextBlock Text="Sipariş, personel ödemeleri ve iptaller otomatik olarak buraya kaydedilir."
                           Style="{StaticResource PageSubtitle}"/>
            </StackPanel>
            <Border Grid.Column="1" Style="{StaticResource CountBadge}">
                <TextBlock x:Name="CountBadge" Foreground="{StaticResource PrimaryBrush}" FontSize="12" FontWeight="SemiBold"/>
            </Border>
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource SectionCard}" Padding="18">
                <StackPanel>
                    <TextBlock Text="Toplam gelir" FontSize="12" Foreground="{StaticResource MutedBrush}"/>
                    <TextBlock x:Name="TotalIncomeText" FontSize="22" FontWeight="Bold"
                               Foreground="#16A34A" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Style="{StaticResource SectionCard}" Padding="18">
                <StackPanel>
                    <TextBlock Text="Toplam gider" FontSize="12" Foreground="{StaticResource MutedBrush}"/>
                    <TextBlock x:Name="TotalExpenseText" FontSize="22" FontWeight="Bold"
                               Foreground="#DC2626" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="4" Style="{StaticResource SectionCard}" Padding="18"
                    Background="{StaticResource AccentSoftBrush}">
                <StackPanel>
                    <TextBlock Text="Net durum" FontSize="12" Foreground="{StaticResource MutedBrush}"/>
                    <TextBlock x:Name="NetTotalText" FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource SectionCard}" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#F8FAFC" BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,0,0,1" Padding="4,4,4,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <Button Style="{StaticResource SortHeaderButton}" Tag="Date" Click="SortHeader_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Tarih" Style="{StaticResource TableHeaderText}"/>
                                <TextBlock x:Name="DateSortArrow" Grid.Column="1" Text="▲" FontSize="10"
                                           Foreground="{StaticResource PrimaryBrush}" Margin="8,0,4,0" VerticalAlignment="Center"/>
                            </Grid>
                        </Button>
                        <Button Grid.Column="1" Style="{StaticResource SortHeaderButton}" Tag="Type" Click="SortHeader_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Tür" Style="{StaticResource TableHeaderText}"/>
                                <TextBlock x:Name="TypeSortArrow" Grid.Column="1" Text="" FontSize="10"
                                           Foreground="{StaticResource PrimaryBrush}" Margin="8,0,4,0" VerticalAlignment="Center"/>
                            </Grid>
                        </Button>
                        <Button Grid.Column="2" Style="{StaticResource SortHeaderButton}" Tag="Category" Click="SortHeader_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Kategori" Style="{StaticResource TableHeaderText}"/>
                                <TextBlock x:Name="CategorySortArrow" Grid.Column="1" Text="" FontSize="10"
                                           Foreground="{StaticResource PrimaryBrush}" Margin="8,0,4,0" VerticalAlignment="Center"/>
                            </Grid>
                        </Button>
                        <Button Grid.Column="3" Style="{StaticResource SortHeaderButton}" Tag="Description" Click="SortHeader_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Açıklama" Style="{StaticResource TableHeaderText}"/>
                                <TextBlock x:Name="DescriptionSortArrow" Grid.Column="1" Text="" FontSize="10"
                                           Foreground="{StaticResource PrimaryBrush}" Margin="8,0,4,0" VerticalAlignment="Center"/>
                            </Grid>
                        </Button>
                        <Button Grid.Column="4" Style="{StaticResource SortHeaderButton}" Tag="Amount" Click="SortHeader_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Tutar" Style="{StaticResource TableHeaderText}"/>
                                <TextBlock x:Name="AmountSortArrow" Grid.Column="1" Text="" FontSize="10"
                                           Foreground="{StaticResource PrimaryBrush}" Margin="8,0,4,0" VerticalAlignment="Center"/>
                            </Grid>
                        </Button>
                    </Grid>
                </Border>

                <ListView x:Name="EntriesList" Grid.Row="1" BorderThickness="0" Background="Transparent"
                          Padding="8,4" SelectionChanged="EntriesList_SelectionChanged">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,2"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <Border x:Name="row" Background="Transparent" CornerRadius="8" Padding="4,2">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="row" Property="Background" Value="#F8FAFC"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="row" Property="Background" Value="{StaticResource AccentSoftBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="8,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding CreatedAtDisplay}" FontSize="13"
                                           Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding EntryType}" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{Binding TypeBrush}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="{Binding Category}" FontSize="13"
                                           Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="3" Text="{Binding Description}" FontSize="13"
                                           Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Column="4" Text="{Binding AmountDisplay}" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{Binding TypeBrush}" VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <Border Grid.Row="2" Style="{StaticResource FooterBar}">
                    <TextBlock x:Name="FooterHint" Foreground="{StaticResource MutedBrush}" FontSize="12"
                               VerticalAlignment="Center" Text="Kayıtlar otomatik oluşturulur."/>
                </Border>

                <TextBlock x:Name="EmptyText" Grid.Row="1"
                           Text="Henüz gelir/gider kaydı yok. Sipariş veya personel ödemesi yapıldığında burada görünür."
                           Foreground="{StaticResource MutedBrush}" FontSize="14"
                           HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,40" TextWrapping="Wrap"
                           TextAlignment="Center" MaxWidth="420"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
