<UserControl x:Class="StokYonetim.Views.Pages.StockPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Stok Takibi" Style="{StaticResource PageTitle}"/>
                <TextBlock x:Name="PageSubtitle" Text="Ürün stoklarını hızlı tuşlarla veya klavyeden sayı girerek düzenleyin."
                           Style="{StaticResource PageSubtitle}"/>
            </StackPanel>
            <Border Grid.Column="1" Style="{StaticResource CountBadge}">
                <TextBlock x:Name="SummaryBadge" Foreground="{StaticResource PrimaryBrush}" FontSize="12" FontWeight="SemiBold"/>
            </Border>
        </Grid>

        <Border Grid.Row="1" Style="{StaticResource SectionCard}" Padding="16" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="200"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="SearchBox" Style="{StaticResource InputBox}"
                         TextChanged="SearchBox_TextChanged"/>
                <TextBlock Grid.Column="1" x:Name="SummaryText" VerticalAlignment="Center" Margin="16,0,0,0"
                           Foreground="{StaticResource MutedBrush}" FontSize="13" HorizontalAlignment="Right"
                           Visibility="Collapsed"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="StockList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1" CornerRadius="12" Padding="16" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextBrush}"/>
                                    <TextBlock Text="{Binding CategoryName}" FontSize="13"
                                               Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                                    <TextBlock Text="Stok:" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}"
                                               Margin="0,0,10,0" FontSize="14"/>
                                    <TextBlock Text="{Binding StockQuantity}" FontSize="28" FontWeight="Bold"
                                               Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center"
                                               MinWidth="48" TextAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CanEdit}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <Button Content="-10" Style="{StaticResource StockAdjustButton}" Margin="0,0,6,0"
                                            Tag="{Binding Id}" Click="Adjust_Click" CommandParameter="-10"/>
                                    <Button Content="-1" Style="{StaticResource StockAdjustButton}" Margin="0,0,6,0"
                                            Tag="{Binding Id}" Click="Adjust_Click" CommandParameter="-1"/>
                                    <Button Content="+1" Style="{StaticResource StockAdjustButton}" Margin="0,0,6,0"
                                            Tag="{Binding Id}" Click="Adjust_Click" CommandParameter="1"/>
                                    <Button Content="+10" Style="{StaticResource StockAdjustButton}" Margin="0,0,12,0"
                                            Tag="{Binding Id}" Click="Adjust_Click" CommandParameter="10"/>

                                    <TextBox Width="72" Style="{StaticResource InputBox}" Padding="8,6"
                                             Text="{Binding InputStock, UpdateSourceTrigger=PropertyChanged}"
                                             PreviewTextInput="StockInput_PreviewTextInput"
                                             KeyDown="StockInput_KeyDown" Tag="{Binding Id}"
                                             VerticalAlignment="Center" TextAlignment="Center"/>
                                    <Button Content="Kaydet" Style="{StaticResource PrimaryButton}" Margin="8,0,0,0"
                                            Tag="{Binding Id}" Click="SaveInput_Click" Padding="12,8"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <TextBlock x:Name="EmptyText" Grid.Row="2" Text="Stok takibi için önce kategori ve ürün ekleyin."
                   Foreground="{StaticResource MutedBrush}" FontSize="14"
                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
    </Grid>
</UserControl>
