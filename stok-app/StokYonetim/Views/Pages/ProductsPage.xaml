<UserControl x:Class="StokYonetim.Views.Pages.ProductsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Ürünler" Style="{StaticResource PageTitle}"/>
                <TextBlock Text="Ürün ekleyin, düzenlemek için ürüne çift tıklayın. Listeyi sütun başlıklarından sıralayın."
                           Style="{StaticResource PageSubtitle}"/>
            </StackPanel>
            <Border Grid.Column="1" Style="{StaticResource CountBadge}">
                <TextBlock x:Name="CountBadge" Foreground="{StaticResource PrimaryBrush}" FontSize="12" FontWeight="SemiBold"/>
            </Border>
        </Grid>

        <Border x:Name="ToolbarPanel" Grid.Row="1" Style="{StaticResource SectionCard}" Padding="20" Margin="0,0,0,16">
            <Grid>
                <TextBlock Text="Kayıtlı ürünler aşağıda listelenir." Foreground="{StaticResource MutedBrush}"
                           FontSize="13" VerticalAlignment="Center"/>
                <Button x:Name="AddProductBtn" Content="Ürün ekle" Style="{StaticResource PrimaryButton}"
                        HorizontalAlignment="Right" MinWidth="130" Height="42" Click="AddProduct_Click"/>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource SectionCard}" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#F8FAFC" BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,0,0,1" Padding="4,4,4,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="150"/>
                        </Grid.ColumnDefinitions>
                        <Button Style="{StaticResource SortHeaderButton}" Tag="Name" Click="SortHeader_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Ürün" Style="{StaticResource TableHeaderText}"/>
                                <TextBlock x:Name="NameSortArrow" Grid.Column="1" Text="▲" FontSize="10"
                                           Foreground="{StaticResource PrimaryBrush}" Margin="8,0,4,0"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Button>
                        <Button Grid.Column="1" Style="{StaticResource SortHeaderButton}" Tag="Category" Click="SortHeader_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Kategori" Style="{StaticResource TableHeaderText}"/>
                                <TextBlock x:Name="CategorySortArrow" Grid.Column="1" Text="" FontSize="10"
                                           Foreground="{StaticResource PrimaryBrush}" Margin="8,0,4,0"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Button>
                        <Button Grid.Column="2" Style="{StaticResource SortHeaderButton}" Tag="Price" Click="SortHeader_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Fiyat" Style="{StaticResource TableHeaderText}"/>
                                <TextBlock x:Name="PriceSortArrow" Grid.Column="1" Text="" FontSize="10"
                                           Foreground="{StaticResource PrimaryBrush}" Margin="8,0,4,0"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Button>
                        <Button Grid.Column="3" Style="{StaticResource SortHeaderButton}" Tag="Stock" Click="SortHeader_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Stok" Style="{StaticResource TableHeaderText}"/>
                                <TextBlock x:Name="StockSortArrow" Grid.Column="1" Text="" FontSize="10"
                                           Foreground="{StaticResource PrimaryBrush}" Margin="8,0,4,0"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Button>
                        <Button Grid.Column="4" Style="{StaticResource SortHeaderButton}" Tag="Created" Click="SortHeader_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Eklenme" Style="{StaticResource TableHeaderText}"/>
                                <TextBlock x:Name="CreatedSortArrow" Grid.Column="1" Text="" FontSize="10"
                                           Foreground="{StaticResource PrimaryBrush}" Margin="8,0,4,0"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Button>
                    </Grid>
                </Border>

                <ListView x:Name="ProductList" Grid.Row="1" BorderThickness="0" Background="Transparent"
                          Padding="8,4" SelectionChanged="ProductList_SelectionChanged"
                          MouseDoubleClick="ProductList_MouseDoubleClick">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,2"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <Border x:Name="row" Background="Transparent" CornerRadius="8" Padding="4,2">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="row" Property="Background" Value="#F8FAFC"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="row" Property="Background" Value="{StaticResource AccentSoftBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="8,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="150"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding CategoryName}" FontSize="13"
                                           Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="{Binding UnitPriceDisplay}" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="3" Text="{Binding StockQuantity}" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="4" Text="{Binding CreatedAtLocal}" FontSize="13"
                                           Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <Border Grid.Row="2" Style="{StaticResource FooterBar}">
                    <Grid>
                        <TextBlock x:Name="FooterHint" Foreground="{StaticResource MutedBrush}" FontSize="12"
                                   VerticalAlignment="Center" Text="Sıralamak için sütun başlığına tıklayın."/>
                        <Button Content="Seçili ürünü sil" Style="{StaticResource DangerButton}"
                                HorizontalAlignment="Right" Click="Delete_Click" IsEnabled="False" x:Name="DeleteBtn"/>
                    </Grid>
                </Border>

                <TextBlock x:Name="EmptyText" Grid.Row="1" Text="Henüz ürün yok. Ürün ekle butonuyla başlayın."
                           Foreground="{StaticResource MutedBrush}" FontSize="14"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
