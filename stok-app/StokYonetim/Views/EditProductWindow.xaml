<Window x:Class="StokYonetim.Views.EditProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ürün Düzenle" Height="540" Width="480" MinHeight="500" MinWidth="420"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource BgBrush}" WindowStyle="SingleBorderWindow">
    <Grid Margin="16">
        <Border Background="White" CornerRadius="12" BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1" Padding="24,24,24,20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Ürünü düzenle" FontSize="20" FontWeight="Bold"
                           Foreground="{StaticResource TextBrush}" Margin="0,0,0,6"/>
                <TextBlock Grid.Row="1" Text="Ürün bilgilerini güncelleyin ve kaydedin."
                           Foreground="{StaticResource MutedBrush}" FontSize="13" Margin="0,0,0,20"/>

                <StackPanel Grid.Row="2" Margin="0,0,0,14">
                    <TextBlock Text="Ürün adı" Style="{StaticResource FormLabel}"/>
                    <TextBox x:Name="NameBox" Style="{StaticResource InputBox}" MaxLength="200"/>
                </StackPanel>

                <StackPanel Grid.Row="3" Margin="0,0,0,14">
                    <TextBlock Text="Kategori" Style="{StaticResource FormLabel}"/>
                    <ComboBox x:Name="CategoryCombo" Style="{StaticResource AppComboBox}"
                              DisplayMemberPath="Name"/>
                </StackPanel>

                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Birim fiyat (₺)" Style="{StaticResource FormLabel}"/>
                        <TextBox x:Name="PriceBox" Style="{StaticResource InputBox}" MaxLength="14"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Stok adedi" Style="{StaticResource FormLabel}"/>
                        <TextBox x:Name="StockBox" Style="{StaticResource InputBox}" MaxLength="8"/>
                    </StackPanel>
                </Grid>

                <TextBlock Grid.Row="5" x:Name="ErrorText" Foreground="#DC2626" FontSize="13"
                           Margin="0,12,0,0" Visibility="Collapsed" TextWrapping="Wrap"/>

                <Grid Grid.Row="6" Margin="0,24,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Content="İptal" Style="{StaticResource SecondaryButton}" Height="44"
                            Click="Cancel_Click"/>
                    <Button Grid.Column="2" Content="Kaydet" Style="{StaticResource PrimaryButton}" Height="44"
                            Click="Save_Click"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
