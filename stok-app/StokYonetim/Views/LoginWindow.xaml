<Window x:Class="StokYonetim.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Kılağuz Elektrik — Giriş" Height="620" Width="920"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#F8FAFC">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="400"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#1D4ED8" Offset="0"/>
                    <GradientStop Color="#1E40AF" Offset="0.5"/>
                    <GradientStop Color="#0F172A" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Ellipse Width="320" Height="320" Fill="#14FFFFFF" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-80,-80,0,0"/>
                <Ellipse Width="240" Height="240" Fill="#0FFFFFFF" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-60,-60"/>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="360">
                    <Border Background="White" CornerRadius="16" Padding="18" HorizontalAlignment="Center" Margin="0,0,0,28">
                        <Image Source="/Assets/kilaguz-logo.png" Width="96" Height="96" Stretch="Uniform"/>
                    </Border>
                    <TextBlock Text="Kılağuz Elektrik" FontSize="30" FontWeight="Bold" Foreground="White"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Yönetim Paneli" FontSize="14" Foreground="#BFDBFE" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Margin="0,6,0,0"/>
                    <TextBlock Text="Stok ve ürün yönetimi için güvenli giriş yapın."
                               Foreground="#CBD5E1" FontSize="13" TextAlignment="Center"
                               Margin="0,16,0,0" TextWrapping="Wrap" LineHeight="20"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Sağ panel — giriş formu -->
        <Border Grid.Column="1" Background="White" Padding="40,48">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Hoş geldiniz" FontSize="26" FontWeight="Bold" Foreground="#0F172A"/>
                <TextBlock Text="Yönetici hesabınızla giriş yapın" Foreground="#64748B" FontSize="14" Margin="0,6,0,32"/>

                <TextBlock Text="E-posta" Foreground="#475569" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <TextBox x:Name="EmailBox" Style="{StaticResource InputBox}" Margin="0,0,0,18"
                         KeyDown="Input_KeyDown"/>

                <TextBlock Text="Şifre" Foreground="#475569" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="44"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.ColumnSpan="2" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Background="White">
                        <Grid>
                            <PasswordBox x:Name="PasswordBox" Padding="12,10" FontSize="14" Background="Transparent"
                                         BorderThickness="0" VerticalAlignment="Center"
                                         KeyDown="PasswordBox_KeyDown"/>
                            <TextBox x:Name="PasswordText" Padding="12,10" FontSize="14" Background="Transparent"
                                     BorderThickness="0" VerticalAlignment="Center" Visibility="Collapsed"
                                     KeyDown="Input_KeyDown"/>
                        </Grid>
                    </Border>
                    <Button Grid.Column="1" x:Name="TogglePasswordBtn" Click="TogglePassword_Click"
                            Background="Transparent" BorderThickness="0" Cursor="Hand" ToolTip="Şifreyi göster / gizle"
                            VerticalAlignment="Center" HorizontalAlignment="Center" Width="36" Height="36">
                        <Path x:Name="EyeIcon" Data="M12,4.5C7,4.5 2.73,7.61 1,12c1.73,4.39 6,7.5 11,7.5s9.27,-3.11 11,-7.5c-1.73,-4.39 -6,-7.5 -11,-7.5zM12,17c-2.76,0 -5,-2.24 -5,-5s2.24,-5 5,-5 5,2.24 5,5 -2.24,5 -5,5zM12,9c-1.66,0 -3,1.34 -3,3s1.34,3 3,3 3,-1.34 3,-3 -1.34,-3 -3,-3z"
                              Fill="#64748B" Stretch="Uniform" Width="20" Height="20"/>
                    </Button>
                </Grid>

                <Border x:Name="CapsLockBanner" Visibility="Collapsed" Margin="0,8,0,0"
                        Background="{StaticResource AccentSoftBrush}" BorderBrush="#BFDBFE" BorderThickness="1"
                        CornerRadius="8" Padding="10,8">
                    <StackPanel Orientation="Horizontal">
                        <Viewbox Width="18" Height="18" Margin="0,0,8,0">
                            <Path Fill="{StaticResource PrimaryBrush}"
                                  Data="M6,18 L18,18 L18,16 L6,16 Z M12,4 L4,10 L7,10 L7,16 L17,16 L17,10 L20,10 Z"/>
                        </Viewbox>
                        <TextBlock Text="Caps Lock açık" Foreground="{StaticResource PrimaryBrush}"
                                   FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <TextBlock x:Name="ErrorText" Foreground="#DC2626" FontSize="13" TextWrapping="Wrap"
                           Margin="0,8,0,0" Visibility="Collapsed"/>

                <Button x:Name="LoginBtn" Content="Giriş yap" Style="{StaticResource PrimaryButton}"
                        Margin="0,24,0,0" Height="44" FontSize="14" Click="Login_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
