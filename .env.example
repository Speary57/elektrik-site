# Bu dosyayı kopyalayıp ".env" adıyla kaydedin ve değerleri doldurun.
# .env dosyası git'e eklenmez (güvenli).

# Yerel geliştirme
DEBUG=1
ALLOWED_HOSTS=localhost,127.0.0.1

# Canlı sunucu (Render vb.) — örnek:
# DEBUG=0
# SECRET_KEY=uzun-rastgele-bir-anahtar
# ALLOWED_HOSTS=elektrik-site.onrender.com
# CSRF_TRUSTED_ORIGINS=https://elektrik-site.onrender.com
# SITE_URL=https://elektrik-site.onrender.com
#
# ÖNEMLİ: Render ücretsiz planda SQLite her deploy'da sıfırlanır.
# Kalıcı veri için Render'da PostgreSQL oluşturup web servisine bağlayın:
#   Dashboard → New PostgreSQL → Web Service → Environment → DATABASE_URL (otomatik eklenir)
# Build Command: ./build.sh
# Start Command: gunicorn config.wsgi:application --bind 0.0.0.0:$PORT

# Yerel geliştirme — Gmail SMTP
EMAIL_HOST_USER=kilaguzelektrik@gmail.com
EMAIL_HOST_PASSWORD=buraya16haneliuygulamasifresi
ORDER_NOTIFICATION_EMAIL=kilaguzelektrik@gmail.com

# Render canlı sunucu — Gmail SMTP ÇALIŞMAZ, Resend kullanın (https://resend.com)
# RESEND_API_KEY=re_xxxxxxxx
# DEFAULT_FROM_EMAIL=onboarding@resend.dev
# (Kendi domaininizi doğruladıktan sonra: noreply@kilaguzelektrik.com)

# Django yönetim paneli (/yonetim/) — Render ortam değişkenlerine ekleyin
ADMIN_USERNAME=admin
ADMIN_EMAIL=alispeary57@gmail.com
